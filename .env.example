# =========================================================================
# mangetout — variables d'environnement (EXEMPLE)
# Copier vers .env et remplir. .env est gitignoré. Dépôt PUBLIC : zéro secret.
# =========================================================================

# --- App (Expo) — préfixe EXPO_PUBLIC_ = embarqué dans le bundle (NON secret) ---
# URL publique de l'API backend (PocketBase derrière Traefik)
EXPO_PUBLIC_PB_URL=https://pb.example.com
# URL du proxy IA (sidecar derrière Traefik)
EXPO_PUBLIC_AI_URL=https://ai.example.com
# Mode d'auth : oidc | password
EXPO_PUBLIC_AUTH_MODE=oidc
# Nom du provider OIDC générique configuré côté PocketBase (à valider au setup)
EXPO_PUBLIC_OIDC_PROVIDER=oidc
# Feature flag IA
EXPO_PUBLIC_AI_ENABLED=true

# --- Serveur proxy IA (server/) — SECRETS, jamais dans le bundle app ---
# Clé OpenRouter (UNIQUE, tous modèles). Vit UNIQUEMENT côté serveur.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Slugs modèles (vérifier la dispo courante sur OpenRouter avant prod)
AI_MODEL_TEXT=deepseek/deepseek-v4-flash
AI_MODEL_TEXT_PRO=deepseek/deepseek-v4-pro
AI_MODEL_VISION=google/gemini-2.5-flash
# URL PocketBase joignable depuis le sidecar (réseau interne Docker)
PB_INTERNAL_URL=http://pocketbase:8090
# Compte de service PocketBase pour les actions coach owner-scoped (à créer)
PB_SERVICE_TOKEN=
# Rate-limit IA (req / min / utilisateur)
AI_RATE_LIMIT_PER_MIN=20

# --- PocketBase (infra) ---
# Identifiants admin initiaux (à créer au 1er lancement, NE PAS committer)
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=
# Version image épinglée
POCKETBASE_VERSION=0.30.0

# --- OIDC (Authelia <-> PocketBase) ---
# Secret client OIDC généré côté Authelia (NE PAS committer)
OIDC_CLIENT_ID=mangetout
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=https://auth.example.com

# --- Sauvegarde restic (pb_data -> stockage distant) ---
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
