# Normalisation des fins de ligne : LF partout (évite le bruit CRLF sous Windows).
* text=auto eol=lf

# Scripts shell : LF obligatoire (sinon cassés à l'exécution).
*.sh text eol=lf
*.mjs text eol=lf

# Binaires : jamais de conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.keystore binary
