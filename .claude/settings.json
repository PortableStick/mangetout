{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-bash.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-check.mjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npx jest:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run lint:*)",
      "Bash(node .claude/hooks/gate.mjs:*)"
    ]
  }
}
