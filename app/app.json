{
  "expo": {
    "name": "mangetout",
    "slug": "mangetout",
    "version": "0.1.0",
    "scheme": "mangetout",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.mangetout.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-splash-screen",
      [
        "expo-camera",
        {
          "cameraPermission": "mangetout utilise la caméra pour scanner les codes-barres des produits."
        }
      ],
      "react-native-health-connect",
      [
        "expo-image-picker",
        {
          "cameraPermission": "mangetout utilise la caméra pour scanner étiquettes, assiettes et machines."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "24e07734-0e43-4001-97e1-eaced5614b3a"
      }
    },
    "owner": "portablestick"
  }
}
