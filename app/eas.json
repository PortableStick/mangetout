{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_PB_URL": "https://pb.example.com",
        "EXPO_PUBLIC_AI_URL": "https://ai.example.com",
        "EXPO_PUBLIC_AUTH_MODE": "oidc",
        "EXPO_PUBLIC_OIDC_PROVIDER": "oidc",
        "EXPO_PUBLIC_AI_ENABLED": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_PB_URL": "https://pb.example.com",
        "EXPO_PUBLIC_AI_URL": "https://ai.example.com",
        "EXPO_PUBLIC_AUTH_MODE": "oidc",
        "EXPO_PUBLIC_OIDC_PROVIDER": "oidc",
        "EXPO_PUBLIC_AI_ENABLED": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
